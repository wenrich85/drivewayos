# Production env-var template. Copy to .env.production and fill in,
# OR (preferred) set these directly in DigitalOcean App Platform's
# secrets UI. Never commit a filled-in copy.

# --- Phoenix ---
# 64-byte secret used to sign cookies. Generate with:
#   mix phx.gen.secret
SECRET_KEY_BASE=

# Public hostname the app is served at (apex). Used to render
# absolute URLs and for endpoint config.
PHX_HOST=drivewayos.com

# --- Tenant routing ---
# Top-level domain that tenant subdomains live under. With this
# set to "drivewayos.com", the tenant `acme` is reachable at
# https://acme.drivewayos.com.
PLATFORM_HOST=drivewayos.com

# --- Database (DO managed Postgres) ---
DATABASE_URL=ecto://USER:PASS@HOST:PORT/DBNAME?ssl=true
POOL_SIZE=10
# Set to true if your DO database has IPv6 networking
ECTO_IPV6=false

# --- Token signing secrets ---
# Two separate secrets so tenant-customer tokens and platform-operator
# tokens are isolated populations. Each must be 64+ random bytes.
PLATFORM_TOKEN_SIGNING_SECRET=
TOKEN_SIGNING_SECRET=

# --- Stripe ---
# Get these from https://dashboard.stripe.com/connect/onboarding
# (the "Connect" platform settings, not your own products).
STRIPE_CLIENT_ID=ca_xxxx
STRIPE_SECRET_KEY=sk_live_xxxx
# From https://dashboard.stripe.com/webhooks for the platform
# webhook endpoint at https://<PHX_HOST>/webhooks/stripe
STRIPE_WEBHOOK_SECRET=whsec_xxxx

# --- SMTP (Zoho / SES / wherever) ---
# Used by Swoosh for booking confirmation emails. The default
# Mailer config in config/runtime.exs is hardcoded for SMTP; switch
# to the Mailgun / SendGrid adapter there if you prefer an HTTP API.
SMTP_HOST=smtp.zoho.com
SMTP_PORT=587
SMTP_USERNAME=noreply@drivewayos.com
SMTP_PASSWORD=

# --- OAuth (optional; unset = strategy disabled) ---
# Customer-tier OAuth providers. Leave any of these blank in early
# launch; password auth + magic-links is enough.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
